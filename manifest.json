{
  "manifest_version": 3,
  "name": "Luatools extension",
  "version": "1.0.0",
  "description": "Luatools extension",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
